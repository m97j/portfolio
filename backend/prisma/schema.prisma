// backend/prisma/schema.prisma


// =======================
// Datasource
// =======================

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}



// =======================
// Generator
// =======================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}



// =======================
// Enums
// =======================

enum ContentType {
  PROJECT
  DOC
  LOG
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum RelationType {
  REFERENCES
  EXTENDS
  DERIVED_FROM
  RELATED
  PROJECT_RESEARCH
}



// =======================
// Core Entity
// =======================

model Content {
  // Identity
  id        String @id @default(cuid())
  slug      String

  // Core fields
  title     String
  summary   String?
  body      String
  type      ContentType
  status    ContentStatus

  // Presentation
  coverUrl  String?
  language  String?

  // Taxonomy
  taxonomyId String?
  taxonomy   Taxonomy? @relation(fields: [taxonomyId], references: [id])

  // Relations
  tags          TagOnContent[]
  relationsFrom ContentRelation[] @relation("from")
  relationsTo   ContentRelation[] @relation("to")

  // Meta extensions
  projectMeta ProjectMeta?
  docMeta     DocMeta?
  logMeta     LogMeta?

  // Timestamps
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, slug])
}



// =======================
// Content Graph Relation
// =======================

model ContentRelation {
  id        String @id @default(uuid())

  fromId    String
  toId      String
  type      RelationType

  from      Content @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to        Content @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([fromId, toId, type])
}



// =======================
// Tagging
// =======================

model Tag {
  id          String @id @default(cuid())

  label       String
  emoji       String?
  description String

  contents    TagOnContent[]
}

model TagOnContent {
  id        String @id @default(cuid())

  contentId String
  tagId     String

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contentId, tagId])
}



// =======================
// Meta Extensions
// =======================

model ProjectMeta {
  contentId String @id
  content   Content @relation(fields: [contentId], references: [id])

  role      String?
  techStack String[]

  startDate DateTime?
  endDate   DateTime?

  githubUrl String?
  demoUrl   String?
  paperUrl  String?

  featured  Boolean @default(false)
}

model DocMeta {
  contentId   String @id
  content     Content @relation(fields: [contentId], references: [id])

  difficulty  Int?
  domain      String?
  references  String[]

  isEvergreen Boolean @default(true)
}

model LogMeta {
  contentId   String @id
  content     Content @relation(fields: [contentId], references: [id])

  mood        String?
  relatedDate DateTime?
  experimentId String?
}



// =======================
// AI / Cache
// =======================

model ContentEmbedding {
  contentId String @id
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  embedding Unsupported("vector(768)")
  model     String

  updatedAt DateTime @updatedAt
}

model RecommendationCache {
  id        String @id @default(uuid())

  sourceId  String
  targetId  String

  score     Float
  reason    String?
  algorithm String?

  source    Content @relation("RecSource", fields: [sourceId], references: [id])
  target    Content @relation("RecTarget", fields: [targetId], references: [id])

  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@unique([sourceId, targetId])
}



// =======================
// Taxonomy
// =======================

model Taxonomy {
  id        String @id @default(cuid())

  name      String
  slug      String
  path      String
  type      ContentType

  parentId  String?
  parent    Taxonomy? @relation("Tree", fields: [parentId], references: [id])
  children  Taxonomy[] @relation("Tree")

  order     Int?
  createdAt DateTime @default(now())

  @@unique([type, parentId, slug])
  @@unique([type, path])
}
